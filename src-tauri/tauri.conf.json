{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "武技殊影图开图模拟器",
  "version": "0.1.0",
  "identifier": "com.wuji.shadowbox",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "武技殊影图开图模拟器",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680,
        "backgroundColor": "#f6f4ee"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
